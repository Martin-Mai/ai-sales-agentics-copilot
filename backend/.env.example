# =============================================================================
# MySQL 数据库配置（异步 SQLAlchemy 路由需求）
# =============================================================================

# MySQL 数据库服务 IP 地址或主机名
MYSQL_HOST=localhost
# MySQL 端口号（标准默认 3306）
MYSQL_PORT=3306
# 数据库登录用户名
MYSQL_USER=your_username
# 数据库登录密码（请在本地 .env 中填写，勿提交到 Git）
MYSQL_PASSWORD=
# 项目使用的数据库名称
MYSQL_DATABASE=sales_copilot

# =============================================================================
# ChromaDB 向量数据库配置
# =============================================================================

# ChromaDB 数据本地持久化存储目录
CHROMA_PERSIST_DIR=./chroma_data
# 长期记忆集合名称（选填/默认）
LONG_TERM_MEMORY_COLLECTION=long_term_memory

# =============================================================================
# 大语言模型 (LLM) 与 API 配置
# =============================================================================

# OpenAI 或兼容渠道（如 DeepSeek/智谱等）的 API Key（请在本地 .env 中填写，勿提交到 Git）
OPENAI_API_KEY=
# 默认使用的模型名称（例如 deepseek-chat 或 gpt-4o）
MODEL_NAME=deepseek-chat
# 统一的 API 基础请求路径（如使用第三方中转或官方代理，请在此配置）
MODEL_BASE_URL=https://api.deepseek.com/v1

# =============================================================================
# LangGraph Agent 行为控制核心变量
# =============================================================================

# Agent 单次运行的最大思考/工具调用步数限制（防止死循环死抠）
MAX_STEPS=6
# 允许保留的最大历史对话轮数
MAX_HISTORY_TURNS=10
# 触发历史对话自动生成摘要（Summary）的阈值轮数
MAX_HISTORY_BEFORE_SUMMARY=20
# 记忆模块相关：记忆重要性判定阈值
MEMORY_IMPORTANCE_THRESHOLD=0.2
# 记忆模块相关：长效记忆的最大存活天数
MEMORY_DAYS_TO_LIVE=7

# =============================================================================
# 系统鲁棒性与重试机制配置
# =============================================================================

# 工具调用或 API 请求失败时的最大自动重试次数
MAX_RETRIES=2
# 触发重试之间的延迟等待时间（秒）
RETRY_DELAY_SECONDS=1
